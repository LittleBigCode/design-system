{
  "$description": "Diametral Design System — design tokens, single source of truth. Three tiers, all emitted as --ds-* custom properties. A token whose $value is wrapped in {braces} references another token's css variable; the generator emits var(--name). See scripts/build-tokens.mjs.",
  "tier1_primitives": {
    "brand_primary": {
      "noir":   { "name": "ds-noir",   "$type": "color", "$value": "#161616", "$description": "Primary ink / darkest." },
      "blanc":  { "name": "ds-blanc",  "$type": "color", "$value": "#ffffff", "$description": "Pure white surface." },
      "gris":   { "name": "ds-gris",   "$type": "color", "$value": "#767884", "$description": "Brand grey (also the mid neutral / faint ink)." },
      "marron": { "name": "ds-marron", "$type": "color", "$value": "#9f8667", "$description": "Brand brown (warm, editorial)." },
      "kaki":   { "name": "ds-kaki",   "$type": "color", "$value": "#aab0a6", "$description": "Brand khaki." },
      "beige":  { "name": "ds-beige",  "$type": "color", "$value": "#d5d3c4", "$description": "Brand beige." },
      "jaune":  { "name": "ds-jaune",  "$type": "color", "$value": "#f4fbda", "$description": "Pale brand yellow (banner / favicon tile)." }
    },
    "brand_secondary": {
      "rouge":     { "name": "ds-rouge",     "$type": "color", "$value": "#ff2a00", "$description": "Signal red — charter canonical accent." },
      "vert":      { "name": "ds-vert",      "$type": "color", "$value": "#89fc79", "$description": "Bright green. SAMPLED from charter PNG — the swatch label was a copy-paste typo; confirm exact hex with brand owner before 1.0." },
      "bleu":      { "name": "ds-bleu",      "$type": "color", "$value": "#23e2ff", "$description": "Bright cyan-blue secondary." },
      "jaune_vif": { "name": "ds-jaune-vif", "$type": "color", "$value": "#fff73b", "$description": "Vivid yellow secondary." }
    },
    "neutral": {
      "grey_light": { "name": "ds-grey-light", "$type": "color", "$value": "#f5f5f5", "$description": "Lightest surface grey (whitesmoke)." },
      "grey_faint": { "name": "ds-grey-faint", "$type": "color", "$value": "#e4e4e6", "$description": "Soft hairline divider grey." },
      "grey":       { "name": "ds-grey",       "$type": "color", "$value": "#cdced0", "$description": "Standard rule / border grey." },
      "grey_dark":  { "name": "ds-grey-dark",  "$type": "color", "$value": "#434649", "$description": "Soft ink (secondary text)." }
    },
    "functional": {
      "green":    { "name": "ds-green",    "$type": "color", "$value": "#2e7d4f", "$description": "Success hue (muted green)." },
      "green_bg": { "name": "ds-green-bg", "$type": "color", "$value": "#eef4ef", "$description": "Success tint." },
      "orange":   { "name": "ds-orange",   "$type": "color", "$value": "#ff5500", "$description": "Warning hue / the app's pre-charter signal orange." },
      "orange_bg":{ "name": "ds-orange-bg","$type": "color", "$value": "#fff0e8", "$description": "Warning / accent tint." },
      "red":      { "name": "ds-red",      "$type": "color", "$value": "#c0392b", "$description": "Danger hue (muted red)." },
      "red_bg":   { "name": "ds-red-bg",   "$type": "color", "$value": "#f9ebe9", "$description": "Danger tint." },
      "info":     { "name": "ds-info",     "$type": "color", "$value": "#1488a6", "$description": "Info hue (harmonized with brand blue)." },
      "info_bg":  { "name": "ds-info-bg",  "$type": "color", "$value": "#eafaff", "$description": "Info tint." },
      "grey_bg":  { "name": "ds-grey-bg",  "$type": "color", "$value": "#ececec", "$description": "Neutral / critical light background." }
    }
  },
  "tier2_semantic": {
    "surface": {
      "bg":            { "name": "ds-bg",            "$type": "color", "$value": "{ds-blanc}",            "$description": "Page background." },
      "bg_alt":        { "name": "ds-bg-alt",        "$type": "color", "$value": "{ds-grey-light}",       "$description": "Secondary / sunken background." },
      "surface":       { "name": "ds-surface",       "$type": "color", "$value": "{ds-blanc}",            "$description": "Raised surface (cards, panels)." },
      "overlay_scrim": { "name": "ds-overlay-scrim", "$type": "color", "$value": "rgba(22, 22, 22, .5)",  "$description": "Modal backdrop scrim." }
    },
    "text": {
      "ink":       { "name": "ds-ink",       "$type": "color", "$value": "{ds-noir}",      "$description": "Primary text." },
      "ink_soft":  { "name": "ds-ink-soft",  "$type": "color", "$value": "{ds-grey-dark}", "$description": "Secondary text." },
      "ink_faint": { "name": "ds-ink-faint", "$type": "color", "$value": "{ds-gris}",      "$description": "Tertiary text / labels." },
      "on_accent": { "name": "ds-on-accent", "$type": "color", "$value": "{ds-blanc}",     "$description": "Text on accent fills." },
      "on_status": { "name": "ds-on-status", "$type": "color", "$value": "{ds-blanc}",     "$description": "Text on solid status heads." }
    },
    "line": {
      "rule":      { "name": "ds-rule",      "$type": "color", "$value": "{ds-grey}",       "$description": "Standard 1px rule." },
      "rule_soft": { "name": "ds-rule-soft", "$type": "color", "$value": "{ds-grey-faint}", "$description": "Soft 1px divider." }
    },
    "accent": {
      "accent":        { "name": "ds-accent",        "$type": "color", "$value": "{ds-rouge}",     "$description": "Brand signal accent (#ff2a00)." },
      "accent_bg":     { "name": "ds-accent-bg",     "$type": "color", "$value": "{ds-orange-bg}", "$description": "Accent tint." },
      "accent_legacy": { "name": "ds-accent-legacy", "$type": "color", "$value": "{ds-orange}",    "$description": "Pre-charter accent #ff5500, kept for pixel-frozen migration." },
      "focus_ring":    { "name": "ds-focus-ring",    "$type": "color", "$value": "{ds-ink}",       "$description": "Focus outline color." }
    },
    "status": {
      "success":     { "name": "ds-success",     "$type": "color", "$value": "{ds-green}",   "$description": "Success." },
      "success_bg":  { "name": "ds-success-bg",  "$type": "color", "$value": "{ds-green-bg}","$description": "Success tint." },
      "warning":     { "name": "ds-warning",     "$type": "color", "$value": "{ds-orange}",  "$description": "Warning." },
      "warning_bg":  { "name": "ds-warning-bg",  "$type": "color", "$value": "{ds-orange-bg}","$description": "Warning tint." },
      "danger":      { "name": "ds-danger",      "$type": "color", "$value": "{ds-red}",     "$description": "Danger / error." },
      "danger_bg":   { "name": "ds-danger-bg",   "$type": "color", "$value": "{ds-red-bg}",  "$description": "Danger tint." },
      "critical":    { "name": "ds-critical",    "$type": "color", "$value": "{ds-noir}",    "$description": "Critical / most severe (the app's 'interdit')." },
      "critical_bg": { "name": "ds-critical-bg", "$type": "color", "$value": "{ds-grey-bg}", "$description": "Critical tint." },
      "neutral":     { "name": "ds-neutral",     "$type": "color", "$value": "{ds-gris}",    "$description": "Neutral / pending status." },
      "neutral_bg":  { "name": "ds-neutral-bg",  "$type": "color", "$value": "{ds-grey-bg}", "$description": "Neutral tint." }
    }
  },
  "tier3_scale": {
    "space": {
      "1": { "name": "ds-space-1", "$type": "dimension", "$value": "4px" },
      "2": { "name": "ds-space-2", "$type": "dimension", "$value": "8px" },
      "3": { "name": "ds-space-3", "$type": "dimension", "$value": "12px" },
      "4": { "name": "ds-space-4", "$type": "dimension", "$value": "16px" },
      "5": { "name": "ds-space-5", "$type": "dimension", "$value": "24px" },
      "6": { "name": "ds-space-6", "$type": "dimension", "$value": "32px" },
      "7": { "name": "ds-space-7", "$type": "dimension", "$value": "40px" },
      "8": { "name": "ds-space-8", "$type": "dimension", "$value": "80px" }
    },
    "radius": {
      "none": { "name": "ds-radius-none", "$type": "dimension", "$value": "0", "$description": "The flat parti pris. Override to round the whole system at once." }
    },
    "type": {
      "2xs":  { "name": "ds-text-2xs",  "$type": "dimension", "$value": "11px" },
      "xs":   { "name": "ds-text-xs",   "$type": "dimension", "$value": "12px" },
      "sm":   { "name": "ds-text-sm",   "$type": "dimension", "$value": "13px" },
      "base": { "name": "ds-text-base", "$type": "dimension", "$value": "14px" },
      "md":   { "name": "ds-text-md",   "$type": "dimension", "$value": "19px" },
      "lg":   { "name": "ds-text-lg",   "$type": "dimension", "$value": "22px" },
      "xl":   { "name": "ds-text-xl",   "$type": "dimension", "$value": "24px" },
      "2xl":  { "name": "ds-text-2xl",  "$type": "dimension", "$value": "32px" },
      "leading_tight":  { "name": "ds-leading-tight",  "$type": "number", "$value": "110%" },
      "leading_normal": { "name": "ds-leading-normal", "$type": "number", "$value": "130%" }
    },
    "font": {
      "title":        { "name": "ds-font-title",        "$type": "fontFamily", "$value": "\"Ufficio\", \"Fraunces\", \"PP Editorial New\", Georgia, \"Times New Roman\", serif", "$description": "Ufficio renders only if ufficio.css is imported (license required); else Fraunces." },
      "sans":         { "name": "ds-font-sans",         "$type": "fontFamily", "$value": "\"Geist\", system-ui, \"Helvetica Neue\", \"Helvetica\", \"Arial\", sans-serif" },
      "weight_title": { "name": "ds-font-weight-title", "$type": "number",     "$value": "300" }
    },
    "layout": {
      "maxw_page":    { "name": "ds-maxw-page",    "$type": "dimension", "$value": "1440px" },
      "maxw_content": { "name": "ds-maxw-content", "$type": "dimension", "$value": "1180px" },
      "maxw_modal":   { "name": "ds-maxw-modal",   "$type": "dimension", "$value": "860px" },
      "bp_md":        { "name": "ds-bp-md",        "$type": "dimension", "$value": "940px", "$description": "Mirrored by hard-coded @media queries." }
    },
    "z": {
      "popover": { "name": "ds-z-popover", "$type": "number", "$value": "60" },
      "header":  { "name": "ds-z-header",  "$type": "number", "$value": "40" },
      "overlay": { "name": "ds-z-overlay", "$type": "number", "$value": "80" },
      "toast":   { "name": "ds-z-toast",   "$type": "number", "$value": "90" }
    },
    "motion": {
      "transition":      { "name": "ds-transition",      "$type": "transition", "$value": ".2s ease" },
      "transition_slow": { "name": "ds-transition-slow", "$type": "transition", "$value": ".25s ease" }
    }
  },
  "compat_aliases": {
    "color_black":       { "name": "ds-color-black",       "$type": "color", "$value": "{ds-noir}" },
    "color_white":       { "name": "ds-color-white",       "$type": "color", "$value": "{ds-blanc}" },
    "color_grey_light":  { "name": "ds-color-grey-light",  "$type": "color", "$value": "{ds-grey-light}" },
    "color_grey":        { "name": "ds-color-grey",        "$type": "color", "$value": "{ds-grey}" },
    "color_grey_medium": { "name": "ds-color-grey-medium", "$type": "color", "$value": "{ds-gris}" },
    "color_grey_dark":   { "name": "ds-color-grey-dark",   "$type": "color", "$value": "{ds-grey-dark}" },
    "color_beige":       { "name": "ds-color-beige",       "$type": "color", "$value": "{ds-beige}" },
    "color_yellow":      { "name": "ds-color-yellow",      "$type": "color", "$value": "{ds-jaune}" },
    "color_red":         { "name": "ds-color-red",         "$type": "color", "$value": "{ds-accent-legacy}" }
  }
}
